variables:
    NC: "nest"
    ASM: "nvma"

targets:
  all:
    deps: [prepare, 4everloop, Nutils/echo]

  prepare:
    cmds:
      - "mkdir -p ../../bin"

  4everloop:
    cmds:
      - "${ASM} ${@}.asm ../../bin/${@F}.bin"

  Nutils/echo:
    cmds:
      - "${NC} ${@}.nest ../../bin/${@F}"

  clean:
    cmds:
      - "rm -rf ../../bin/*"